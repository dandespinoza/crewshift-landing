    "react-dom": "^19.0.0",
    "@supabase/supabase-js": "^2.45.0",
    "sharp": "^0.33.0",
    "graphql": "^16.9.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
